{
  "expo": {
    "name": "EscánerRecibos",
    "slug": "receipt-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "receipt-scanner",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dev.receiptscanner",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para fotografiar recibos y boletas.",
        "NSPhotoLibraryUsageDescription": "Accedemos a tus fotos para subir recibos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dev.receiptscanner",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite acceder a tus fotos para subir recibos.",
          "cameraPermission": "Permite tomar fotos de recibos y boletas."
        }
      ]
    ]
  }
}
